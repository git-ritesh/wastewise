# Backend environment template (local + production)
# Copy this file to .env for local development.
# In Render, add the same keys in Environment variables.

# App
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://127.0.0.1:5173,https://your-frontend-domain.com

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d
UNVERIFIED_ACCOUNT_TTL_MINUTES=30

# Brevo API (recommended for production)
BREVO_API_KEY=your_brevo_api_key
BREVO_API_TIMEOUT_MS=15000
BREVO_SENDER_EMAIL=no-reply@yourdomain.com
BREVO_SENDER_NAME=WasteWise

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
